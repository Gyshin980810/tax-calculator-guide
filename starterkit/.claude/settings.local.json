{
  "permissions": {
    "allow": [
      "Bash(npx --yes create-next-app@latest . --typescript --tailwind --eslint --app --src-dir --import-alias \"@/*\" --use-npm --turbopack --no-install)",
      "Bash(npx --yes shadcn@latest init --yes --base-color neutral --css-variables)",
      "Bash(npx --yes shadcn@latest init --yes)",
      "Bash(npx --yes shadcn@latest init --help)",
      "Bash(npx --yes shadcn@latest init -b radix -y -f)",
      "Bash(npm install *)",
      "Bash(npx tsc *)",
      "Bash(git config *)",
      "Bash(git remote *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "mcp__context7__resolve-library-id",
      "Bash(git push *)",
      "Bash(gh pr *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Skill(update-config)",
      "Bash(npm run *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run validate:fast"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git push *)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run validate"
          }
        ]
      }
    ]
  }
}
